{
  "description": "Risk Category derivation logic per ASCE 7-16 Table 1.5-1",
  "reference": "ASCE 7-16 §1.5, Table 1.5-1",
  "derivation_rules": {
    "priority_order": [
      "risk_category_IV",
      "risk_category_III",
      "risk_category_II",
      "risk_category_I"
    ],
    "note": "Evaluate in priority order — highest matching category wins",
    "risk_category_IV": {
      "category": "IV",
      "description": "Essential facilities — required for post-disaster response",
      "wind_speed_figure": "26.5-1C",
      "triggers": [
        "essential_post_disaster = true AND occupancy_type IN [hospital, fire_station, police_station, emergency_shelter, emergency_operations_center, power_generation, water_treatment, aviation_control_tower]"
      ]
    },
    "risk_category_III": {
      "category": "III",
      "description": "Substantial hazard to human life in the event of failure",
      "wind_speed_figure": "26.5-1C",
      "triggers": [
        "hazardous_materials = true",
        "assembly_occupancy = true AND occupant_load >= 300",
        "occupancy_type IN [school, daycare, college] AND occupant_load >= 250",
        "healthcare_24hr = true AND occupant_load >= 50",
        "occupancy_type IN [jail, detention_center, correctional_facility]",
        "power_generating_station = true AND not_risk_cat_IV = true"
      ]
    },
    "risk_category_II": {
      "category": "II",
      "description": "Standard occupancy — default for most buildings",
      "wind_speed_figure": "26.5-1A",
      "triggers": [
        "all buildings not classified as Risk Category I, III, or IV"
      ]
    },
    "risk_category_I": {
      "category": "I",
      "description": "Low hazard to human life in the event of failure",
      "wind_speed_figure": "26.5-1B",
      "triggers": [
        "occupancy_type IN [agricultural_facility, temporary_facility, minor_storage]",
        "occupant_load <= 5 AND not_essential = true"
      ]
    }
  },
  "occupancy_type_map": {
    "office": "risk_category_II",
    "retail": "risk_category_II",
    "warehouse": "risk_category_II",
    "industrial": "risk_category_II",
    "multifamily_residential": "risk_category_II",
    "single_family_residential": "risk_category_II",
    "hotel": "risk_category_II",
    "parking_garage": "risk_category_II",
    "restaurant": "risk_category_II",
    "school": "risk_category_III",
    "daycare": "risk_category_III",
    "college_university": "risk_category_III",
    "stadium_arena": "risk_category_III",
    "assembly_hall": "risk_category_III",
    "jail_detention": "risk_category_III",
    "hospital": "risk_category_IV",
    "fire_station": "risk_category_IV",
    "police_station": "risk_category_IV",
    "emergency_operations_center": "risk_category_IV",
    "water_treatment_facility": "risk_category_IV",
    "power_generating_station": "risk_category_III",
    "aviation_control_tower": "risk_category_IV",
    "agricultural_facility": "risk_category_I",
    "temporary_facility": "risk_category_I",
    "minor_storage": "risk_category_I"
  }
}
